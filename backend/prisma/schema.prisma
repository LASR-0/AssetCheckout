generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma_client"
}

datasource db {
  provider = "sqlite"
}

/* ===================== REQUESTS ===================== */
model Request {
  id             Int      @id @default(autoincrement())

  userId         Int

  userName       String

  categoryId     Int
  categoryName   String

  requestType    RequestType
  status         RequestStatus @default(PENDING)

  reason         String?
  manager        String?

  callText       Boolean @default(false)
  newNumber      Boolean @default(false)

  approvedBy     String?
  approvedAt     DateTime?
  rejectedBy        String?
  rejectedAt        DateTime?

  modelRequest   ModelRequest?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/* ===================== MODEL REQUESTS ===================== */
model ModelRequest {
  id             Int      @id @default(autoincrement())

  requestId      Int      @unique
  request        Request  @relation(fields: [requestId], references: [id])

// Working buffer for the admin's Create Model form. Persisted on partial submits
// so the form can resume if Snipe-IT creation fails midway. Populated by admin
// during model creation, not by the requester.
  manufacturer   String?
  modelName      String?
  modelNumber    String?
  price          Float?

  linkedAssetId  Int?
  snipeModelId   Int?

  status         ModelRequestStatus @default(PENDING)
  assetReady     Boolean            @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/* ===================== SETTINGS ===================== */
model Setting {
  key         String   @id
  value       String   // JSON-serialized or plain string depending on key
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // actor's email at time of last write
}

/* ===================== BACKGROUND JOBS ===================== */

model BackgroundJob {
  id            Int       @id @default(autoincrement())
  type          JobType
  status        JobStatus @default(Pending)
  payload       String?   // JSON string
  resultSummary String?   // JSON string
  errorMessage  String?
  scheduledAt   DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  createdAt     DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([type])
}

/* ===================== ENUMS ===================== */
enum RequestType {
  STANDARD
  NON_STANDARD
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ModelRequestStatus {
  PENDING
  APPROVED
  COMPLETED
}

enum JobType {
  SEND_REQUEST_NOTIFICATION
  SYNC_REQUEST_TO_SHAREPOINT
  REFRESH_CATEGORIES_CACHE
  REFRESH_PRICES_CACHE
  CLEANUP_STALE_REQUESTS
  CLEANUP_ORPHAN_SNIPE_MODELS
  PURGE_OLD_JOB_HISTORY
}

enum JobStatus {
  Pending
  Running
  Completed
  Failed
}