# ============================================================================
# Backend environment variables
# ============================================================================
# Copy this file to `.env` in the same directory and fill in real values.
# The .env file is git-ignored; only this template is tracked.
#
# Required for the server to boot: SNIPEIT_API_URL, SNIPEIT_BOT_TOKEN,
# ADMIN_EMAILS, DATABASE_URL. The others have sensible defaults.
# ============================================================================


# ----------------------------------------------------------------------------
# Snipe-IT connection
# ----------------------------------------------------------------------------
# The base URL of your Snipe-IT instance, including protocol. No trailing
# slash. The backend calls this to fetch assets, models, statuses, etc.
#
# Examples:
#   https://snipe.yourcompany.com
#   https://snipeit.internal.example.org
SNIPEIT_API_URL=

# API token for a Snipe-IT service account ("bot user"). The bot needs
# permissions to read assets/models/categories AND to create assets +
# check assets in/out. See README for the minimum permission set.
#
# Generate at: Snipe-IT → your bot user → Edit User → API tokens.
SNIPEIT_BOT_TOKEN=


# ----------------------------------------------------------------------------
# Server config
# ----------------------------------------------------------------------------
# Port the Express server listens on. Should match VITE_API_BASE_URL on the
# frontend (e.g. backend on 3000 → frontend points to http://localhost:3000).
PORT=3000

# Used in a few places to gate dev-only behaviour (e.g. verbose logging).
# Set to "production" when deploying.
NODE_ENV=development


# ----------------------------------------------------------------------------
# Admin allowlist
# ----------------------------------------------------------------------------
# Comma-separated list of email addresses that should automatically be granted
# the ADMIN role. Matched against the X-User-Email header (injected by Caddy
# from the HRT session) in production, or the x-dev-user-email header in dev.
#
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=


# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
#
# The project uses SQLite by default. The file is created automatically by
# `prisma migrate dev`. If you want to change paths or move to another
# database engine, update both this value AND the `provider` in
# prisma/schema.prisma.
DATABASE_URL="file:./src/db/database.db"


# ----------------------------------------------------------------------------
# Background jobs
# ----------------------------------------------------------------------------
# These override the hardcoded defaults seeded into the Setting table on first
# startup. Once a setting has been written via the admin UI, env-var changes
# here are ignored — env vars only seed values that don't already exist in
# the database.
#
# Uncomment and adjust if you want non-default cadences for a particular
# deployment. Cron expressions follow the standard 5-field format:
# minute hour day-of-month month day-of-week.

# How often the job runner polls for pending work (milliseconds).
#JOBS_POLL_INTERVAL_MS=5000

# Completed/failed BackgroundJob rows older than this many days are purged
# by the daily cleanup job.
#JOBS_HISTORY_RETENTION_DAYS=90

# Cron schedule for refreshing the Snipe-IT category cache (default: hourly).
#JOBS_REFRESH_CATEGORIES_CRON=0 * * * *

# Cron schedule for refreshing the Snipe-IT price-averages cache
# (default: every 10 minutes).
#JOBS_REFRESH_PRICES_CRON=*/10 * * * *

# Cron schedule for the stale-request cleanup job (default: daily midnight).
#JOBS_CLEANUP_STALE_CRON=0 0 * * *

# Cron schedule for the orphan Snipe-model cleanup job
# (default: weekly Sunday at 2am).
#JOBS_CLEANUP_ORPHAN_CRON=0 2 * * 0

# Cron schedule for the BackgroundJob history purge (default: daily 3am).
#JOBS_PURGE_HISTORY_CRON=0 3 * * *

#Cron options for cleaning up orphaned models
#JOBS_ORPHAN_CLEANUP_DRY_RUN=true
#JOBS_ORPHAN_CLEANUP_MAX_DELETES=5


# ----------------------------------------------------------------------------
# HRT integration
# ----------------------------------------------------------------------------
# Shared secret for machine-to-machine calls from NextHRT (the /api/integrations/hrt/*
# routes: device requests, Snipe user creation, and exit offboarding). NextHRT
# sends this in the X-API-Key header; set the same value in HRT's
# ASSET_CHECKOUT_API_KEY. Leave unset to disable the integration endpoints.
#
# Generate with e.g.: openssl rand -hex 32
HRT_API_KEY=

# ----------------------------------------------------------------------------
# Setting Seeding
# ----------------------------------------------------------------------------
# ---- Settings seeding (applied on FIRST creation of each setting row only;
# ---- admin UI changes are never overwritten by these) ----


# SKELETON_STATUS_ID=
# SHIPPING_ESTIMATE_DAYS=5
# JOBS_SHIPMENT_REMINDER_CRON=0 10 * * *
# REMINDER_DAYS_1=7
# REMINDER_DAYS_2=14
# REMINDER_DAYS_3=30
# FEEDBACK_ENABLED=true
# SHAREPOINT_SYNC_ENABLED=false
# MOBILE_COUNTRY_CODE=61
# MOBILE_LEADING_DIGIT=4

# REQUESTABLE_CATEGORY_IDS=1,2,5,9
#   (comma-separated or JSON [1,2,5,9]; empty = all categories allowed)
# STANDARD_MODELS_JSON={"3":{"primary":42,"backup":57},"7":{"primary":12,"backup":null}}
#   (JSON only; keys are categoryId strings, values are Snipe model IDs)
