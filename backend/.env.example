# ============================================================================
# Backend environment variables
# ============================================================================
# Copy this file to `.env` in the same directory and fill in real values.
# The .env file is git-ignored; only this template is tracked.
#
# Required for the server to boot: SNIPEIT_API_URL, SNIPEIT_BOT_TOKEN,
# ADMIN_EMAILS, DATABASE_URL. The others have sensible defaults or gate
# optional features (email, SharePoint sync, HRT integration).
#
# ----------------------------------------------------------------------------
# How settings seeding works (read this before editing the seed vars below)
# ----------------------------------------------------------------------------
# Every SEEDED setting maps 1:1 to a row in the Setting table: the env var
# named here IS the value stored under the matching setting key, applied on
# FIRST creation of that row only. On a fresh production rebuild this imports
# your whole configuration with no UI clicks. Once a setting has been written
# via the admin UI, env-var changes here are ignored — env vars only seed
# rows that don't already exist.
#
# CANONICAL FORM: the list/object settings (REQUESTABLE_CATEGORY_IDS,
# STANDARD_MODELS_JSON, REQUESTABLE_ACCESSORY_CATEGORY_IDS,
# STANDARD_ACCESSORIES_JSON) accept either JSON or, for the ID lists,
# comma-separated values — but they are canonicalised to JSON in the DB.
# Seed them as JSON so "what's in .env" always equals "what's in the DB".
# ============================================================================


# ----------------------------------------------------------------------------
# Snipe-IT connection
# ----------------------------------------------------------------------------
# The base URL of your Snipe-IT instance, including protocol. No trailing
# slash. The backend calls this to fetch assets, models, categories, etc.
#
# Examples:
#   https://snipe.yourcompany.com
#   https://snipeit.internal.example.org
SNIPEIT_API_URL=

# API token for a Snipe-IT service account ("bot user"). The bot needs
# permissions to read assets/models/categories AND to create assets +
# check assets in/out, plus view + checkout/checkin on accessories. See
# README for the minimum permission set.
#
# Generate at: Snipe-IT → your bot user → Edit User → API tokens.
SNIPEIT_BOT_TOKEN=


# ----------------------------------------------------------------------------
# Server config
# ----------------------------------------------------------------------------
# Port the Express server listens on. Should match VITE_API_BASE_URL on the
# frontend (e.g. backend on 3000 → frontend points to http://localhost:3000).
PORT=3000

# SECURITY-RELEVANT. Anything other than "development" is treated as
# production: the backend then ignores the x-dev-user-* impersonation headers
# entirely and trusts only the proxy-injected X-User-* identity. Also gates
# dev-only behaviour like verbose logging. Set explicitly to "production"
# when deploying.
NODE_ENV=development

# The app's public base URL (as users reach it, through the proxy). Used to
# build the links and CTA buttons inside notification emails. No trailing
# slash.
#
# Example: APP_BASE_URL=https://checkout.yourcompany.com
APP_BASE_URL=


# ----------------------------------------------------------------------------
# Admin allowlist
# ----------------------------------------------------------------------------
# Comma-separated list of email addresses that are granted the ADMIN role.
# Matched against the X-User-Email header injected by your authenticating
# reverse proxy in production, or the x-dev-user-email header in development.
# Also the recipient list for admin notifications (IT sign-off needed,
# overdue-shipment escalations).
#
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# Comma-separated admin display names, used by the DEVELOPMENT auth path
# (the x-dev-user-* impersonation flow), which works with names where
# production works with the proxy-verified email. Not used for production
# role resolution — that is ADMIN_EMAILS only.
ADMIN_NAMES=


# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
#
# The project uses SQLite by default. The file is created automatically by
# `prisma migrate dev`. If you want to change paths or move to another
# database engine, update both this value AND the `provider` in
# prisma/schema.prisma.
DATABASE_URL="file:./src/db/database.db"


# ----------------------------------------------------------------------------
# Email (SMTP)
# ----------------------------------------------------------------------------
# Powers request notifications, shipment reminders, and the SharePoint sync
# transport. Optional: with SMTP_HOST/SMTP_FROM unset the app runs normally,
# but email-sending jobs will fail (visibly, in the job history).
#
# The transport connects on SMTP_PORT and enforces STARTTLS — it refuses to
# send if the TLS upgrade fails. Certificate validation is disabled (internal
# relay); see the Email section of the documentation before pointing this at
# anything other than a trusted internal relay.

# Relay hostname, e.g. smtp01.internal.example.com
SMTP_HOST=

# Relay port. 587 (STARTTLS) is the default.
SMTP_PORT=587

# LOGIN credentials (a service account), if your relay requires auth.
# Leave BOTH empty for an IP-allowlisted anonymous relay.
SMTP_USER=
SMTP_PASS=

# The sender address for all outgoing mail — whatever your mail admins have
# assigned/permitted for this host.
SMTP_FROM=


# ----------------------------------------------------------------------------
# SharePoint sync
# ----------------------------------------------------------------------------
# The service mailbox the nightly request-ledger sync emails payloads to
# (a Power Automate flow on that mailbox creates the SharePoint list items).
# Leave unset to skip the sync entirely. The sync also has a master toggle,
# sharepoint_sync_enabled (seeded below, default false) — both must be set
# for the sync to run, and the schedule comes from JOBS_SHAREPOINT_SYNC_CRON
# (also below).
SHAREPOINT_SYNC_TO=


# ----------------------------------------------------------------------------
# HRT integration
# ----------------------------------------------------------------------------
# Shared secret for machine-to-machine calls from NextHRT (the
# /api/integrations/hrt/* routes: device requests, the category catalogue,
# Snipe user creation/lookup, and exit offboarding). NextHRT sends this in
# the X-API-Key header; set the same value in HRT's ASSET_CHECKOUT_API_KEY.
# Leave unset to disable the integration endpoints (they respond 503).
#
# The token is the sole guard on these routes — keep them on the internal
# network. Generate with e.g.: openssl rand -hex 32
HRT_API_KEY=


# ----------------------------------------------------------------------------
# Background jobs
# ----------------------------------------------------------------------------
# These override the hardcoded defaults seeded into the Setting table on first
# startup. Once a setting has been written via the admin UI, env-var changes
# here are ignored — env vars only seed values that don't already exist in
# the database.
#
# Uncomment and adjust if you want non-default cadences for a particular
# deployment. Cron expressions follow the standard 5-field format:
# minute hour day-of-month month day-of-week.

# How often the job runner polls for pending work (milliseconds).
#JOBS_POLL_INTERVAL_MS=5000

# Completed/failed BackgroundJob rows older than this many days are purged
# by the daily cleanup job.
#JOBS_HISTORY_RETENTION_DAYS=90

# Cron schedule for refreshing the Snipe-IT category cache (default: hourly).
#JOBS_REFRESH_CATEGORIES_CRON=0 * * * *

# Cron schedule for refreshing the Snipe-IT price-averages cache
# (default: every 10 minutes).
#JOBS_REFRESH_PRICES_CRON=*/10 * * * *

# Cron schedule for refreshing the Snipe-IT accessories + accessory-categories
# caches (default: every 10 minutes).
#JOBS_REFRESH_ACCESSORIES_CRON=*/10 * * * *

# Cron schedule for the stale-request cleanup job (default: daily midnight).
#JOBS_CLEANUP_STALE_CRON=0 0 * * *

# Cron schedule for the orphan Snipe-model cleanup job
# (default: weekly Sunday at 2am).
#JOBS_CLEANUP_ORPHAN_CRON=0 2 * * 0

# Cron schedule for the BackgroundJob history purge (default: daily 3am).
#JOBS_PURGE_HISTORY_CRON=0 3 * * *

# Cron schedule for the shipped-request reminder scan (default: daily 10am).
#JOBS_SHIPMENT_REMINDER_CRON=0 10 * * *

# Cron schedule for the nightly SharePoint request-ledger sync
# (default: daily 1am). Gated additionally by SHAREPOINT_SYNC_ENABLED +
# SHAREPOINT_SYNC_TO — this only controls WHEN the scan fires. Without this
# seeded, the scheduler has no cron for the sync and silently skips it.
#JOBS_SHAREPOINT_SYNC_CRON=0 1 * * *

# Months of inactivity before a non-terminal request is auto-rejected by the
# stale-request cleanup job.
#JOBS_STALE_REQUEST_MONTHS=6

# Orphan-model cleanup guard rails: dry-run mode (report only, no deletion —
# review a dry-run result before setting false) and the per-run deletion cap.
#JOBS_ORPHAN_CLEANUP_DRY_RUN=true
#JOBS_ORPHAN_CLEANUP_MAX_DELETES=5


# ----------------------------------------------------------------------------
# Settings seeding
# ----------------------------------------------------------------------------
# Applied on FIRST creation of each setting row only; admin UI changes are
# never overwritten by these.

# Snipe-IT status ID for newly-created skeleton assets. Empty falls back to
# looking up the "Pending" status by name.
#SKELETON_STATUS_ID=

# Delivery estimate (days) quoted in the "your device has shipped" email.
#SHIPPING_ESTIMATE_DAYS=5

# Shipment reminder escalation thresholds (days after shipping): first nudge,
# second nudge, then overdue escalation to the user AND all admins.
#REMINDER_DAYS_1=7
#REMINDER_DAYS_2=14
#REMINDER_DAYS_3=30

# Whether the anonymous feedback feature is active (page, nudge, and CTA).
#FEEDBACK_ENABLED=true

# Master toggle for the nightly SharePoint request-ledger sync. Enable once
# the receiving mailbox (SHAREPOINT_SYNC_TO) is deliverable from your relay
# and the Power Automate flow is live. Schedule is JOBS_SHAREPOINT_SYNC_CRON.
#SHAREPOINT_SYNC_ENABLED=false

# Mobile number recognition — region config for telling mobiles from
# landlines when resolving numbers from Snipe-IT. Defaults are Australian
# (+61 4xx / 04xx).
#MOBILE_COUNTRY_CODE=61
#MOBILE_LEADING_DIGIT=4

# --- Requestable catalogue (assets) ------------------------------------------
# Requestable asset categories (JSON array preferred; comma-separated also
# accepted, e.g. 1,2,5,9). Empty = all asset categories allowed.
#REQUESTABLE_CATEGORY_IDS=[1,2,5,9]

# Standard asset models (JSON only). Keys are categoryId strings; values are
# { primary, backup } Snipe model IDs.
#STANDARD_MODELS_JSON={"3":{"primary":42,"backup":57},"7":{"primary":12,"backup":null}}

# --- Requestable catalogue (accessories) -------------------------------------
# Requestable accessory categories (JSON array preferred; comma-separated also
# accepted). Empty = all accessory categories allowed.
#REQUESTABLE_ACCESSORY_CATEGORY_IDS=[11,14,18]

# Standard accessories (JSON only). Keys are accessory categoryId strings;
# each value is { options: [{ label, primary, backup }] } where label is the
# requester-facing choice and primary/backup are representative Snipe
# accessory IDs.
#STANDARD_ACCESSORIES_JSON={"11":{"options":[{"label":"USB-C to USB-C","primary":21,"backup":null},{"label":"USB-C to Lightning","primary":22,"backup":null}]}}
