# ============================================================================
# Frontend environment variables
# ============================================================================
# Copy this file to `.env` in the same directory and fill in real values.
# All variables MUST be prefixed with `VITE_` to be exposed to client code —
# this is a Vite requirement, not a project convention.
#
# The .env file is git-ignored; only this template is tracked.
# ============================================================================


# ----------------------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------------------
# Where the backend API lives. The frontend issues fetch() calls against
# this base URL.
#
# In dev: matches the backend's PORT (3000 by default).
# In production: point to wherever your backend is hosted.
VITE_API_BASE_URL=http://localhost:3000


# ----------------------------------------------------------------------------
# Build / runtime flags
# ----------------------------------------------------------------------------
# Free-form environment label. Used in a few places to gate dev-only UI.
VITE_APP_ENV=development

# Network timeout for backend requests, in milliseconds.
VITE_API_TIMEOUT=5000

# Toggle verbose console logging. Set to "false" in production.
VITE_ENABLE_LOGS=true


# ----------------------------------------------------------------------------
# Branding — company name + logo (all optional)
# ----------------------------------------------------------------------------
# Shown in the navbar. When unset, the navbar reads "Checkout Central"
# without a company prefix. When set, reads "{COMPANY_NAME} Checkout Central".
VITE_COMPANY_NAME=

# Theme-aware logo paths. Logic:
#   LIGHT set + DARK set    → uses whichever matches the active theme
#   LIGHT set + DARK unset  → always uses LIGHT (graceful fallback)
#   LIGHT unset             → no logo shown at all
#
# Paths can be:
#   - Local public folder paths (recommended): /branding/logo.png
#     (place the file at frontend/public/branding/logo.png)
#   - External URLs: https://cdn.example.com/logo.png
VITE_LOGO_PATH_LIGHT=
VITE_LOGO_PATH_DARK=


# ----------------------------------------------------------------------------
# Page watermarks (all optional)
# ----------------------------------------------------------------------------
# Optional decorative images shown on the No Access (403) and Not Found
# (404) pages. Each follows the same LIGHT/DARK fallback pattern as the
# logo above: dark version is optional, light is required to enable the
# watermark at all. When unset, the page renders its fallback icon
# treatment instead.

# Not Found (404 / catch-all) page
VITE_CATCH_ALL_WATERMARK_LIGHT=
VITE_CATCH_ALL_WATERMARK_DARK=

# No Access (403) page
VITE_NO_ACCESS_WATERMARK_LIGHT=
VITE_NO_ACCESS_WATERMARK_DARK=
